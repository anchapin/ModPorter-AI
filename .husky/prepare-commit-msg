#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Automatically prepend issue number from branch name if available
# Example: feature/689-enable-ai-commits -> [#689]
branch_name=$(git rev-parse --abbrev-ref HEAD)
issue_number=$(echo "$branch_name" | grep -oE '[0-9]+' | head -1)

if [ -n "$issue_number" ] && ! grep -q "#$issue_number" "$1"; then
  sed -i.bak -e "1s/^/[#$issue_number] /" "$1"
  rm -f "$1.bak"
fi
