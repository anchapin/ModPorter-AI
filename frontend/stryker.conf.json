{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "testRunnerNodeArgs": ["--experimental-vm-modules"],
  "reporters": ["html", "json", "clear-text"],
  "mutate": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.d.ts",
    "!src/**/*.test.{ts,tsx}",
    "!src/**/*.spec.{ts,tsx}",
    "!src/**/*.stories.{ts,tsx}",
    "!src/**/mocks/**",
    "!src/pages/**",
    "!src/components/ui/**",
    "!src/components/ConversionUpload/**",
    "!src/components/ConversionReport/**",
    "!src/components/ConversionProgress/**",
    "!src/components/ConversionFlow/**",
    "!src/components/ConversionHistory/**",
    "!src/components/ConversionDashboard/**",
    "!src/components/BatchConversion/**",
    "!src/components/BehaviorEditor/**",
    "!src/components/BehavioralTest/**",
    "!src/components/AdvancedOptions/**",
    "!src/components/Onboarding/**",
    "!src/components/NotificationSystem/**",
    "!src/components/MermaidDiagram/**",
    "!src/components/TopNavigation/**",
    "!src/components/PerformanceBenchmark/**",
    "!src/components/BehaviorTemplatesContext/**",
    "!src/context/**",
    "!src/contexts/**",
    "!src/stories/**",
    "!src/App.tsx",
    "!src/main.tsx"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 70
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**"
  ],
  "concurrency": 4,
  "coverageAnalysis": "off",
  "timeoutMS": 15000,
  "timeoutFactor": 3
}
