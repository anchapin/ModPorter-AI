{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "testRunnerNodeArgs": ["--experimental-vm-modules"],
  "reporters": ["json"],
  "mutate": ["src/services/apiClient.ts", "src/services/queryClient.ts"],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 70
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**"
  ],
  "concurrency": 1,
  "coverageAnalysis": "off",
  "timeoutMS": 60000,
  "timeoutFactor": 1.5,
  "maxConcurrentTestRunners": 1
}
