{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "testRunnerNodeArgs": ["--experimental-vm-modules"],
  "reporters": ["html", "json", "clear-text"],
  "mutate": [
    "src/services/**/*.{ts,tsx}",
    "src/utils/**/*.{ts,tsx}",
    "src/api/**/*.{ts,tsx}",
    "src/types/**/*.{ts,tsx}",
    "!src/**/*.test.{ts,tsx}",
    "!src/**/*.spec.{ts,tsx}",
    "!src/**/*.d.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 70
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**"
  ],
  "concurrency": 6,
  "coverageAnalysis": "off",
  "timeoutMS": 20000,
  "timeoutFactor": 2.5
}
