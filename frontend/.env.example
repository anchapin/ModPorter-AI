# API Configuration
# For development, the Vite proxy will handle API requests (/api/* -> http://localhost:8000)
# For production, set the full API URL including the path

# Development: Leave empty to use proxy (default)
# Production: Set to full URL e.g., https://api.portkit.cloud
VITE_API_BASE_URL=

# Alternative: Set the base URL without /api/v1 (will be derived)
# VITE_API_URL=http://localhost:8000/api/v1

# Sentry Error Tracking Configuration
# Get your DSN from https://sentry.io/settings/<organization>/projects/<project>/keys/
VITE_SENTRY_DSN=

# Sentry sampling rates (0.0 - 1.0)
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# App version (optional, defaults to 1.0.0)
VITE_APP_VERSION=1.0.0

# Enable Sentry in development (optional, for debugging)
# VITE_SENTRY_ENABLE_DEV=true

# Stripe Configuration (Issue #970)
# Get your keys from https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=
