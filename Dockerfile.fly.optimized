# Optimized Dockerfile for fast Fly.io deployments
# Uses BuildKit cache mounts and parallel builds

# syntax=docker/dockerfile:1.6

# =============================================================================
# Stage 1: Frontend build (with cache mount for npm)
# =============================================================================
FROM node:25-alpine AS frontend-builder
WORKDIR /app/frontend

# Use cache mount for node_modules - persists between builds
RUN --mount=type=cache,target=/root/.npm \
    --mount=type=bind,source=frontend/package.json,target=package.json \
    --mount=type=bind,source=frontend/package-lock.json,target=package-lock.json \
    npm ci --legacy-peer-deps

COPY frontend/ ./
ARG VITE_API_URL=https://portkit.cloud/api/v1
ARG VITE_API_BASE_URL=https://portkit.cloud
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

# Build frontend with cache
RUN --mount=type=cache,target=/root/.npm \
    npm run build

# =============================================================================
# Stage 2: Python dependencies (with cache mount for pip)
# =============================================================================
FROM python:3.14-slim AS python-builder
WORKDIR /tmp

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ curl libmagic1 ffmpeg && \
    rm -rf /var/lib/apt/lists/*

# Combine requirements to install in one pass (faster, less conflicts)
COPY backend/requirements.txt /tmp/backend-requirements.txt
COPY ai-engine/requirements.txt /tmp/ai-engine-requirements.txt
RUN echo "# Combined requirements\n" \
    && cat /tmp/backend-requirements.txt /tmp/ai-engine-requirements.txt \
    > /tmp/all-requirements.txt

# Use cache mount for pip - massive speedup on subsequent builds
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -r /tmp/all-requirements.txt

# =============================================================================
# Stage 3: Production image
# =============================================================================
FROM debian:bookworm-slim
WORKDIR /app

# Install only runtime dependencies (remove build tools after Python is ready)
RUN apt-get update && apt-get install -y --no-install-recommends \
    nginx curl postgresql-client redis python3 python3-pip && \
    rm -rf /var/lib/apt/lists/* \
    && ln -sf python3 /usr/bin/python

# Copy Python packages from builder (using correct Python 3.11 path)
COPY --from=python-builder /usr/local/lib/python3.11/site-packages /usr/lib/python3.11/site-packages

# Copy application source code
COPY backend/ /app/backend/
COPY ai-engine/ /app/ai-engine/
COPY backend/src/alembic.ini /app/backend/alembic.ini
COPY --from=frontend-builder /app/frontend/dist /usr/share/nginx/html

# Copy nginx configuration
COPY nginx-fly.conf /etc/nginx/nginx.conf

# Create non-root user with data directory symlinks
RUN groupadd -g 1001 appuser && \
    useradd -u 1001 -g appuser -m appuser && \
    mkdir -p /data/cache /data/temp_uploads /data/conversion_outputs /data/logs /data/db && \
    ln -s /data/cache /app/cache && \
    ln -s /data/temp_uploads /app/temp_uploads && \
    ln -s /data/conversion_outputs /app/conversion_outputs && \
    ln -s /data/logs /app/logs && \
    ln -s /data/db /app/data && \
    chown -R appuser:appuser /app

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost/health || exit 1

# Copy startup scripts
COPY scripts/fly-startup.sh /startup.sh
COPY scripts/run-migrations.sh /app/scripts/run-migrations.sh
RUN chmod +x /startup.sh /app/scripts/run-migrations.sh

EXPOSE 80 443 8000 8001

CMD ["/startup.sh"]
