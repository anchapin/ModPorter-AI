{
  "name": "portkit-vscode",
  "version": "1.0.0",
  "description": "Convert Minecraft Java Edition mods to Bedrock Edition add-ons from VS Code",
  "main": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "keywords": [
    "minecraft",
    "bedrock",
    "addon",
    "conversion",
    "portkit"
  ],
  "author": "PortKit Team",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.6",
    "@vscode/test-electron": "^2.3.8",
    "typescript": "^5.3.3"
  }
}