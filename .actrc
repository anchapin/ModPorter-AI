# Act CLI configuration for local GitHub Actions execution
# See https://github.com/nektos/act

# Default container image to use for running workflows
# Using ubuntu-latest image
-P ubuntu-latest=ghcr.io/catthehacker/ubuntu:full-latest

# Secrets for local testing (leave empty for local CI)
# act will automatically generate tokens for public repos
-s DOCKER_HUB_USERNAME=
-s DOCKER_HUB_ACCESS_TOKEN=

# Environment variables
--env=SKIP_DOCKER_BUILD=false
