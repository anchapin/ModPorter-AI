# API Keys (required for AI functionality)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/modporter
REDIS_URL=redis://localhost:6379

# Backend Configuration
DEBUG=False
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,https://modporter.ai

# Frontend Configuration  
VITE_API_URL=http://localhost:8000

# File Upload Limits
MAX_FILE_SIZE=100MB
MAX_CONVERSION_TIME=600

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100

# Sentry Error Tracking Configuration (Issue #698)
# Get your DSN from https://sentry.io/settings/<organization>/projects/<project>/keys/
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Environment and version (used by Sentry)
ENVIRONMENT=development
APP_VERSION=1.0.0

# Enable Sentry debug mode (optional, for troubleshooting)
SENTRY_ENABLE_DEV=false

# Stripe Configuration (Issue #970)
# Get your keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# App base URL for Stripe redirect URLs
APP_BASE_URL=http://localhost:3000
